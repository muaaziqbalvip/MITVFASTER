rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: never allow client-side reads/writes.
    // All access goes through your server (get.py), which uses the
    // Admin SDK and bypasses these rules entirely.
    match /users/{userId} {
      allow read, write: if false;
    }

    // Channels, movies, series: readable by your admin panel UI only
    // if that admin UI checks auth (recommended: add your own admin
    // Firebase Auth check here). Locked down by default.
    match /channels/{channelId} {
      allow read: if false;
      allow write: if false;
    }
    match /movies/{movieId} {
      allow read: if false;
      allow write: if false;
    }
    match /series/{seriesId} {
      allow read: if false;
      allow write: if false;
    }

    // Sessions: server-only (Admin SDK bypasses rules)
    match /sessions/{sessionId} {
      allow read, write: if false;
    }
  }
}
